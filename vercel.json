{
	"outputDirectory": ".",
	"functions": {
		"api/mcp.ts": {
			"maxDuration": 60
		}
	},
	"rewrites": [
		{
			"source": "/mcp",
			"destination": "/api/mcp"
		},
		{
			"source": "/mcp/oauth",
			"destination": "/api/mcp"
		},
		{
			"source": "/mcp-oauth",
			"destination": "/api/mcp"
		}
	],
	"headers": [
		{
			"source": "/api/mcp",
			"headers": [
				{
					"key": "Access-Control-Allow-Origin",
					"value": "*"
				},
				{
					"key": "Access-Control-Allow-Methods",
					"value": "GET, POST, DELETE, OPTIONS"
				},
				{
					"key": "Access-Control-Allow-Headers",
					"value": "Content-Type, Authorization, x-api-key"
				}
			]
		}
	]
}
