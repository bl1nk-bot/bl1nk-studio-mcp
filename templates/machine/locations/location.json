{
  "type": "location",
  "id": "{{id}}",
  "name": "{{name}}",
  "locationType": "{{locationType}}",
  "region": "{{region}}",
  "significance": "{{significance}}",
  "description": "{{description}}",
  "keyFeatures": [{% for feature in keyFeatures %}"{{feature}}"{% if not loop.last %}, {% endif %}{% endfor %}],
  "associatedCharacters": [{% for char in associatedCharacters %}"{{char}}"{% if not loop.last %}, {% endif %}{% endfor %}],
  "scenesSetHere": [{% for scene in scenesSetHere %}"{{scene}}"{% if not loop.last %}, {% endif %}{% endfor %}],
  "tags": [{% for tag in tags %}"{{tag}}"{% if not loop.last %}, {% endif %}{% endfor %}]
}