{
	"servers": {
		"microsoft/markitdown": {
			"type": "stdio",
			"command": "uvx",
			"args": ["markitdown-mcp@0.0.1a4"],
			"gallery": "https://api.mcp.github.com",
			"version": "1.0.0"
		},
		"io.github.upstash/context7": {
			"type": "stdio",
			"command": "npx",
			"args": ["@upstash/context7-mcp@1.0.31"],
			"env": {
				"CONTEXT7_API_KEY": "${input:CONTEXT7_API_KEY}"
			},
			"gallery": "https://api.mcp.github.com",
			"version": "1.0.31"
		},
		"io.github.vercel/next-devtools-mcp": {
			"type": "stdio",
			"command": "npx",
			"args": ["next-devtools-mcp@0.3.6"],
			"gallery": "https://api.mcp.github.com",
			"version": "0.3.6"
		},
		"neondatabase/mcp-server-neon": {
			"type": "http",
			"url": "https://mcp.neon.tech/sse",
			"gallery": "https://api.mcp.github.com",
			"version": "1.0.0"
		},
		"com.vercel/vercel-mcp": {
			"type": "http",
			"url": "https://mcp.vercel.com",
			"gallery": "https://api.mcp.github.com",
			"version": "0.0.3"
		}
	},
	"inputs": [
		{
			"id": "NETDATA_CLOUD_API_TOKEN",
			"type": "promptString",
			"description": "Netdata Cloud API token (create at app.netdata.cloud > User Settings > API Tokens with scope:mcp)",
			"password": true
		},
		{
			"id": "CONTEXT7_API_KEY",
			"type": "promptString",
			"description": "API key for authentication",
			"password": true
		}
	]
}
