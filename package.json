{
	"name": "bl1nk-visual-mcp-monorepo",
	"version": "3.0.0",
	"private": true,
	"type": "module",
	"engines": {
		"node": ">=22",
		"pnpm": ">=11.5.1"
	},
	"packageManager": "pnpm@11.8.0+sha512.c1f5e7c4cb241c8f174b743851d82f42b802324afc8b0f116b96adb15aa06664948dde36960a3ba1079ba5b4b29dd0140135b94b5b5f5263592249d68e555f26",
	"scripts": {
		"build": "pnpm -r run build",
		"dev": "pnpm -r --parallel run dev",
		"test": "pnpm -r run test",
		"test:audit": "node scripts/audit-tests.js",
		"test:watch": "pnpm -r run test:watch",
		"lint": "biome check . && markdownlint-cli2 \"**/*.md\" \"!**/node_modules/**\" \"!**/dist/**\" \"!**/out/**\" \"!**/.next/**\" \"!**/coverage/**\"",
		"lint:fix": "biome check --write . && markdownlint-cli2 --fix \"**/*.md\"",
		"format": "biome format --write .",
		"typecheck": "pnpm -r run typecheck",
		"clean": "pnpm -r exec rm -rf dist .next out target coverage",
		"clean:all": "pnpm run clean && rm -rf node_modules && pnpm -r exec rm -rf node_modules",
		"hook:pre-commit": "pnpm run lint",
		"docs:update": "node ./scripts/hooks/update-docs.js",
		"hook:task-complete": "pnpm run lint && pnpm run docs:update",
		"hooks:install": "git config core.hooksPath .githooks",
		"mcp:build": "node scripts/build.js build",
		"mcp:check": "node scripts/build.js check"
	},
	"dependencies": {
		"@modelcontextprotocol/sdk": "^1.29.0",
		"@vercel/analytics": "^2.0.1",
		"fs-extra": "^11.3.5",
		"handlebars": "^4.7.9",
		"playwright-core": "^1.61.0",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.16",
		"@esbuild/android-arm64": "^0.28.0",
		"@playwright/test": "^1.60.0",
		"@tailwindcss/vite": "^4.3.0",
		"@tauri-apps/cli": "^2.11.2",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@testing-library/user-event": "^14.6.1",
		"@types/fs-extra": "^11.0.4",
		"@types/node": "^25.9.3",
		"@types/react": "^19.2.17",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^6.0.2",
		"autoprefixer": "^10.5.0",
		"esbuild": "0.27.7",
		"jsdom": "^29.1.1",
		"markdownlint-cli2": "^0.22.1",
		"postcss": "8.5.15",
		"tailwindcss": "^4.3.0",
		"typescript": "^6.0.3",
		"vite": "^8.0.16",
		"vitest": "^4.1.8"
	},
	"overrides": {
		"rollup": "^4.59.0",
		"postcss": "8.5.15",
		"@ai-sdk/provider-utils": "^3.0.98"
	},
	"resolutions": {
		"postcss": "8.5.15"
	}
}
