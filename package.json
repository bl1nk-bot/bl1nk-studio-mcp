{
	"name": "bl1nk-visual-mcp-monorepo",
	"version": "3.0.0",
	"private": true,
	"type": "module",
	"engines": {
		"node": ">=22"
	},
	"scripts": {
		"build": "pnpm -r run build",
		"test": "pnpm -r run test",
		"lint": "pnpm -r run lint",
		"format": "pnpm -r run format",
		"hook:pre-commit": "pnpm lint",
		"docs:update": "node ./scripts/hooks/update-docs.js",
		"hook:task-complete": "pnpm run lint && pnpm run docs:update",
		"hooks:install": "git config core.hooksPath .githooks"
	},
	"dependencies": {
		"@modelcontextprotocol/sdk": "^1.27.1",
		"fs-extra": "^11.3.4",
		"handlebars": "^4.7.9",
		"react": "^19.2.5",
		"zod": "^3.22.4"
	},
	"devDependencies": {
		"@biomejs/biome": "1.9.4",
		"@types/fs-extra": "^11.0.4",
		"@types/node": "^20.11.0",
		"esbuild": "^0.28.0",
		"markdownlint-cli2": "^0.21.0",
		"typescript": "^5.3.3",
		"vitest": "^4.1.2"
	},
	"overrides": {
		"rollup": "^4.59.0"
	}
}
