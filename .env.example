# bl1nk-visual-mcp - Environment Variables

# Optional: MCP Server Configuration
# These are used if you want to run this as an MCP server
MCP_SERVER_PORT=3000
MCP_SERVER_HOST=localhost

# Optional: API Keys (if extending with external services)
# Leave empty if not using external services
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# Exa API Key — required for exa_search_story tool
# Get your key at: https://dashboard.exa.ai/api-keys
EXA_API_KEY=

# Optional: Feature Flags
ENABLE_TELEMETRY=false
DEBUG_MODE=false

# Optional: Project Settings
STORY_DEFAULT_ACT_COUNT=3
STORY_MIN_EVENTS=3
STORY_MAX_EVENTS=100

# ===========================================
# Vercel Deployment Configuration
# ===========================================

# Rate Limiting (Upstash Redis)
# Get your credentials at: https://console.upstash.io/
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Alternative Upstash naming (same as above)
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# Rate Limit Configuration
RATE_LIMIT_QPS=2
RATE_LIMIT_DAILY=50

# OAuth Configuration (for production deployments)
OAUTH_ISSUER=https://mcp.exa.ai
OAUTH_AUDIENCE=exa-mcp-api
OAUTH_JWKS_URI=https://mcp.exa.ai/.well-known/jwks.json

# Bypass Configuration (for internal/testing use)
RATE_LIMIT_BYPASS=
EXA_API_KEY_BYPASS=

# Force OAuth for specific user agents (comma-separated)
OAUTH_USER_AGENTS=

# Enabled Tools (comma-separated, optional - defaults to all)
# ENABLED_TOOLS=analyze_story,export_mermaid,exa_search_story
