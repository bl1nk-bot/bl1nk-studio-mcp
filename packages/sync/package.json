{
	"name": "@bl1nk/sync",
	"version": "3.0.0",
	"type": "module",
	"main": "dist/index.js",
	"scripts": {
		"build": "esbuild src/index.ts --bundle --platform=node --format=esm --outfile=dist/index.js --packages=bundle",
		"start": "node dist/index.js",
		"dev": "esbuild src/index.ts --bundle --platform=node --format=esm --outfile=dist/index.js --packages=bundle --watch",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@bl1nk/core": "workspace:*",
		"@notionhq/client": "^5.22.0",
		"@octokit/webhooks": "^14.2.0",
		"csv-parse": "^6.2.1",
		"gray-matter": "^4.0.3"
	}
}
