{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"outDir": "dist",
		"rootDir": ".",
		"lib": ["DOM", "DOM.Iterable", "ES2023"],
		"types": ["node"],
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"resolveJsonModule": true,
		"noEmit": true
	},
	"include": ["**/*.ts", "**/*.tsx", "env.d.ts"],
	"exclude": [
		"node_modules",
		"dist",
		"known/**/*.json",
		"templates/**/*",
		"notebook/**/*"
	]
}
